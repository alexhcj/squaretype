osts.jsx",["167"],"import React, { useEffect, useState } from 'react'\r\nimport { Preloader } from '../Preloader/Preloader'\r\nimport { posts } from '../../api/posts-api'\r\nimport { PostItem } from './PostItem/PostItem'\r\nimport { Button } from '../UI/Button/Button'\r\nimport s from './Posts.module.sass'\r\n\r\nexport const Posts = () => {\r\n\tconst [posts, setPosts] = useState([])\r\n\tconst [postsQuantity, setPostsQuantity] = useState(0)\r\n\tconst [prev, setPrev] = useState(0)\r\n\tconst [isLoading, setIsLoading] = useState(false)\r\n\tconst [isError, setIsError] = useState(false)\r\n\tconst [firstRender, setFirstRender] = useState(true)\r\n\tconst total = 10\r\n\tconst sortBy = 'date'\r\n\r\n\tuseEffect(() => {\r\n\t\tconst fetchData = async () => {\r\n\t\t\tsetIsError(false)\r\n\t\t\tsetIsLoading(true)\r\n\r\n\t\t\ttry {\r\n\t\t\t\tconst fetchedData = await posts.getPosts(total, prev, sortBy)\r\n\t\t\t\tsetPostsQuantity(fetchedData.length)\r\n\t\t\t\tconst data = [...posts, ...fetchedData]\r\n\t\t\t\tsetPosts(data)\r\n\t\t\t} catch (e) {\r\n\t\t\t\tsetIsError(true)\r\n\t\t\t\tconsole.log(`Error while fetching data: ${e}`)\r\n\t\t\t\tthrow e\r\n\t\t\t}\r\n\t\t\tsetFirstRender(false)\r\n\t\t\tsetIsLoading(false)\r\n\t\t}\r\n\r\n\t\tfetchData()\r\n\t}, [prev])\r\n\r\n\tconst loadMoreHandler = (e) => {\r\n\t\te.preventDefault()\r\n\t\tsetPrev(prev + total)\r\n\t}\r\n\r\n\treturn (\r\n\t\t<div className={s.postsBox}>\r\n\t\t\t<section className={s.posts}>\r\n\t\t\t\t{isError && <div>Something went wrong ...</div>}\r\n\r\n\t\t\t\t{firstRender && isLoading ? (\r\n\t\t\t\t\t<div className={s.preloader}>\r\n\t\t\t\t\t\t<Preloader />\r\n\t\t\t\t\t</div>\r\n\t\t\t\t) : (\r\n\t\t\t\t\tposts.map((post, index) => {\r\n\t\t\t\t\t\treturn <PostItem post={post} key={index} />\r\n\t\t\t\t\t})\r\n\t\t\t\t)}\r\n\t\t\t</section>\r\n\t\t\t{postsQuantity < total ? null : (\r\n\t\t\t\t<div className={s.btnBox}>\r\n\t\t\t\t\t<Button\r\n\t\t\t\t\t\ttext='Load more'\r\n\t\t\t\t\t\ttype='btnPosts'\r\n\t\t\t\t\t\tloadMoreHandler={loadMoreHandler}\r\n\t\t\t\t\t\tisLoading={isLoading}\r\n\t\t\t\t\t/>\r\n\t\t\t\t</div>\r\n\t\t\t)}\r\n\t\t</div>\r\n\t)\r\n}\r\n\r\n// LATER: fix button logic render when posts quantity = total(10)\r\n// NOTE: too much renders(5)\r\n// LATER: make preloader bigger when data is fetching\r\n\r\n// IDEA: when posts ends => offer to search another posts or another logic\r\n\r\n// DONE: 1. posts grid styling\r\n// DONE: 2. add to btn arrow icon\r\n// DONE: 3. set up width, when slow internet aside css crashes. Solution: set up preloader comp to button\r\n// DONE: 4. if loading => SOLO preloader : posts\r\n\r\n// DONE: where would be better sort posts\r\n// 1. the load on server or client is better?\r\n// DONE: node server will choose sort type which came from frontend and sort on server side when find mongoodb Schema EX:(PostText)\r\n// 2. mb allows to use both approaches? pagination on server. other small components on client.\r\n// DONE: by this time all types of queries will pass from front to back and there applyied as params\r\n","C:\\Users\\alex_hcj\\Desktop\\WEB\\Prog\\Node.js\\node_blog\\client\\src\\components\\PostText\\PostText.jsx",[],"C:\\Users\\alex_hcj\\Desktop\\WEB\\Prog\\Node.js\\node_blog\\client\\src\\api\\posts.js",[],"C:\\Users\\alex_hcj\\Desktop\\WEB\\Prog\\Node.js\\node_blog\\client\\src\\utils\\img.js",[],"C:\\Users\\alex_hcj\\Desktop\\WEB\\Prog\\Node.js\\node_blog\\client\\src\\utils\\number.js",[],"C:\\Users\\alex_hcj\\Desktop\\WEB\\Prog\\Node.js\\node_blog\\client\\src\\utils\\date.js",[],"C:\\Users\\alex_hcj\\Desktop\\WEB\\Prog\\Node.js\\node_blog\\client\\src\\components\\Scroll\\Scroll.jsx",[],"C:\\Users\\alex_hcj\\Desktop\\WEB\\Prog\\Node.js\\node_blog\\client\\src\\components\\Navbar\\Navbar.jsx",[],"C:\\Users\\alex_hcj\\Desktop\\WEB\\Prog\\Node.js\\node_blog\\client\\src\\components\\Preloader\\Preloader.jsx",[],"C:\\Users\\alex_hcj\\Desktop\\WEB\\Prog\\Node.js\\node_blog\\client\\src\\compone